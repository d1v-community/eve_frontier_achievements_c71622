    "localnet:update": "pnpm --filter contract localnet:update && pnpm localnet:explorer:start",
    "localnet:deploy": "pnpm --filter contract localnet:deploy",
    "localnet:deploy:no-dependency-check": "pnpm --filter contract localnet:deploy:no-dependency-check",
    "localnet:address": "pnpm --filter contract localnet:address",
    "localnet:explorer:start": "pnpm --filter contract localnet:explorer:start",
    "localnet:explorer:stop": "pnpm --filter contract localnet:explorer:stop",
    "localnet:explorer:restart": "pnpm --filter contract localnet:explorer:restart",
    "devnet:start": "pnpm --filter contract devnet:start",
    "devnet:stop": "pnpm --filter contract devnet:stop",
    "devnet:status": "pnpm --filter contract devnet:status",
    "devnet:links": "pnpm --filter contract devnet:links",
    "devnet:update": "pnpm --filter contract devnet:update",
    "devnet:deploy": "pnpm --filter contract devnet:deploy",
    "devnet:deploy:no-dependency-check": "pnpm --filter contract devnet:deploy:no-dependency-check",
    "devnet:address": "pnpm --filter contract devnet:address",
    "testnet:start": "pnpm --filter contract testnet:start",
    "testnet:stop": "pnpm --filter contract testnet:stop",
    "testnet:status": "pnpm --filter contract testnet:status",
    "testnet:links": "pnpm --filter contract testnet:links",
    "testnet:update": "pnpm --filter contract testnet:update",
    "testnet:probe": "pnpm --filter contract testnet:probe",
    "testnet:register-signer": "pnpm --filter contract testnet:register-signer",
    "testnet:deploy": "pnpm --filter contract testnet:deploy",
    "testnet:deploy:no-dependency-check": "pnpm --filter contract testnet:deploy:no-dependency-check",
    "testnet:address": "pnpm --filter contract testnet:address",
    "mainnet:start": "pnpm --filter contract mainnet:start",
    "mainnet:stop": "pnpm --filter contract mainnet:stop",
    "mainnet:status": "pnpm --filter contract mainnet:status",
    "mainnet:links": "pnpm --filter contract mainnet:links",
    "mainnet:update": "pnpm --filter contract mainnet:update",
    "mainnet:deploy": "pnpm --filter contract mainnet:deploy",
    "mainnet:deploy:no-dependency-check": "pnpm --filter contract mainnet:deploy:no-dependency-check",
    "mainnet:address": "pnpm --filter contract mainnet:address",
    "vercel:preview": "vercel",
    "vercel:prod": "vercel --prod"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "next": "16.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "keywords": [
    "eve-frontier",
    "eve-medals",
    "frontier-chronicle",
    "achievements",
    "sui",
    "sui-move",
    "nextjs",
    "wallet-sync"
  ],
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "!**/test/**"
  ]
}
