{
  "name": "eve-frontier-achievements",
  "version": "0.21.1",
  "description": "EVE Frontier Chronicle medals monorepo on Sui",
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "clean": "pnpm --filter nextjs clean",
    "dev": "pnpm nextjs:dev",
    "start": "pnpm dev",
    "test": "pnpm contract:test",
    "build": "pnpm contract:build && pnpm nextjs:build",
    "lint": "pnpm nextjs:lint",
    "format": "pnpm nextjs:format",
    "nextjs:dev": "pnpm --filter nextjs dev",
    "nextjs:build": "pnpm --filter nextjs build",
    "nextjs:lint": "pnpm --filter nextjs lint",
    "nextjs:preview": "pnpm --filter nextjs preview",
    "nextjs:format": "pnpm --filter nextjs format",
    "nextjs:deploy:firebase:init": "pnpm --filter nextjs deploy:firebase:init",
    "nextjs:deploy:firebase": "pnpm --filter nextjs deploy:firebase",
    "nextjs:deploy:walrus:testnet": "pnpm --filter nextjs deploy:walrus:testnet",
    "nextjs:deploy:walrus:mainnet": "pnpm --filter nextjs deploy:walrus:mainnet",
    "nextjs:deploy:arweave": "pnpm --filter nextjs deploy:arweave",
    "contract:build": "pnpm --filter contract build",
    "contract:test": "pnpm --filter contract test",
